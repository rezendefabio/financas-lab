# ─── Variáveis de ambiente (nunca ignorar .env.example) ──────────────────────
.env
.env.local
.env.*.local

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*

