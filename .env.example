# Template de variáveis de ambiente — copie este arquivo para .env e ajuste se necessário.
# O arquivo .env NÃO é versionado. Este .env.example SIM.

# PostgreSQL - usado pelo docker-compose.yml e (futuro) Spring Boot
POSTGRES_USER=financas
POSTGRES_PASSWORD=changeme_local_only
POSTGRES_DB=financas_dev

# Redis - usado pelo docker-compose.yml e (futuro) Spring Boot
REDIS_PASSWORD=changeme_local_only

# MinIO - usado pelo docker-compose.yml e Spring Boot
MINIO_ROOT_USER=financas
MINIO_ROOT_PASSWORD=financas123
MINIO_BUCKET=financas-lab
MINIO_ENDPOINT=http://localhost:9000
